<Window x:Class="TopCPR.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Top CPR Plus UI (Level 3.5)" Height="650" Width="1040" Background="#111827" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2937" Padding="16">
            <StackPanel>
                <TextBlock Text="Top CPR Plus" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                <Button Content="Dashboard" Height="34" Margin="0,0,0,8" Click="BtnDashboard_Click"/>
                <Button Content="Protection" Height="34" Margin="0,0,0,8" Click="BtnProtection_Click"/>
                <Button Content="Snapshots" Height="34" Margin="0,0,0,8" Click="BtnSnapshots_Click"/>
                <Button Content="Boot Mode" Height="34" Margin="0,0,0,8" Click="BtnBoot_Click"/>
                <Button x:Name="BtnSettings" Content="Settings" Height="34" Margin="0,0,0,8" Click="BtnSettings_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid x:Name="DashboardPanel">
                <StackPanel>
                    <TextBlock Text="Dashboard" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                    <Border Background="#374151" Padding="14" Margin="0,16,0,0" CornerRadius="8">
                        <StackPanel>
                            <TextBlock x:Name="TxtStatus" Text="Status: Unknown" Foreground="White" FontSize="16"/>
                            <TextBlock x:Name="TxtSnapshot" Text="Current Snapshot: NONE" Foreground="White" Margin="0,6,0,0"/>
                            <TextBlock x:Name="TxtHeartbeat" Text="Service: Offline" Foreground="#FCA5A5" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid x:Name="ProtectionPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Protection" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="Enable Restore" Width="160" Height="36" Margin="0,0,10,0" Click="BtnEnable_Click"/>
                        <Button Content="Disable Restore" Width="160" Height="36" Margin="0,0,10,0" Click="BtnDisable_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="SnapshotsPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Snapshots" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                    <ListBox x:Name="LstSnapshots" Margin="0,16,0,0" Height="300" Background="#374151" Foreground="White" BorderThickness="0"/>
                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Create" Width="110" Height="34" Margin="0,0,8,0" Click="BtnCreateSnapshot_Click"/>
                        <Button Content="Restore" Width="110" Height="34" Margin="0,0,8,0" Click="BtnRestoreSnapshot_Click"/>
                        <Button Content="Delete" Width="110" Height="34" Click="BtnDeleteSnapshot_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="BootPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Boot Mode" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="Normal Mode" Width="150" Height="34" Margin="0,0,8,0" Click="BtnSetNormal_Click"/>
                        <Button Content="Restore Mode" Width="150" Height="34" Margin="0,0,8,0" Click="BtnSetRestore_Click"/>
                    </WrapPanel>
                    <TextBox x:Name="TxtTimeout" Text="5" Width="80" Height="30" Margin="0,12,0,0"/>
                    <Button Content="Apply Timeout" Width="130" Height="34" Margin="0,8,0,0" Click="BtnSetTimeout_Click"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Admin Settings" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="New Password" Foreground="White" Margin="0,12,0,4"/>
                    <PasswordBox x:Name="PwdNew" Width="240" Height="30"/>
                    <Button Content="Update Password" Width="160" Height="34" Margin="0,10,0,0" Click="BtnSetPassword_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Border x:Name="LoginOverlay" Grid.ColumnSpan="2" Background="#CC111827">
            <Grid>
                <Border Width="360" Height="240" Background="#1F2937" CornerRadius="10" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Login" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <PasswordBox x:Name="PwdLogin" Height="34" Margin="0,14,0,0"/>
                        <Button Content="Unlock" Height="34" Margin="0,12,0,0" Click="BtnLogin_Click"/>
                        <TextBlock x:Name="TxtLoginHint" Foreground="#FCA5A5" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
